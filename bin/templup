#!/usr/bin/env bash

set -euo pipefail

TEMPLATE_DIR="${1:-$HOME/local/gepetto/nix/templates/default}"

for f in $(git -C "$TEMPLATE_DIR" ls-files)
do
    test -d "$(dirname "$f")" || mkdir -p "$(dirname "$f")"
    test -f "$f" || cp {"$TEMPLATE_DIR/",}"$f"
    diff -q {"$TEMPLATE_DIR/",}"$f" || nvim -d {"$TEMPLATE_DIR/",}"$f"
    grep -q CHANGEME "$f" || nvim "$f"
done
