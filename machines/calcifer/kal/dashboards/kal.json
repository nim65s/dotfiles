        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Kal",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "spec": {
                        "query": "import \"math\"\nimport \"strings\"\n\nfrom(bucket: \"kal\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) =>\n    r._measurement =~ /kal\\/tele\\/.+\\/(temperature|humidity)$/\n    and r._field == \"value\"\n    and r._value != \"\"\n  )\n  |> map(fn: (r) => {\n      parts = strings.split(v: r._measurement, t: \"/\")\n\n      return {\n        _time: r._time,\n        device: parts[2],\n        metric: parts[3],\n        _value: float(v: r._value),\n      }\n  })\n  |> group(columns: [\"device\", \"metric\"])\n  |> aggregateWindow(every: 1m, fn: mean, createEmpty: false)\n  |> pivot(\n      rowKey: [\"_time\", \"device\"],\n      columnKey: [\"metric\"],\n      valueColumn: \"_value\"\n  )\n  |> filter(fn: (r) =>\n      exists r.temperature and exists r.humidity\n  )\n  |> map(fn: (r) => {\n      a = 17.27\n      b = 237.7\n      alpha = (a * r.temperature) / (b + r.temperature) + \n              math.log(x: r.humidity / 100.0)\n      d = (b * alpha) / (a - alpha)\n\n      h = r.temperature + 0.5555 * (\n        6.11 * math.exp(x: 5417.7530 * (\n          1.0 / 273.16 - 1.0 / (273.15 + d)\n        ))\n      )\n\n\n      return {\n        _time: r._time,\n        device: r.device,\n        dew_point: d,\n        temperature: r.temperature,\n        humidity: r.humidity,\n        humidex: h,\n      }\n  })"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "spec": {
                        "query": "import \"strings\"\nfrom(bucket: \"kal\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) =>\n    r._measurement =~ /kal\\/tele\\/.+\\/relay$/\n    and contains(\n      value: strings.split(v: r._measurement, t: \"/\")[2],\n      set: ${device:json}\n    )\n    and r._field == \"value\"\n  )\n  |> map(fn: (r) => ({\n      r with\n      _value: bool(v: r._value == \"On\"),\n  }))\n  |> drop(columns: [\"kind\", \"_field\"])"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "spec": {
                        "query": "import \"strings\"\nfrom(bucket: \"kal\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) =>\n    r._measurement =~ /kal\\/tele\\/.+\\/target$/\n    and contains(\n      value: strings.split(v: r._measurement, t: \"/\")[2],\n      set: ${device:json}\n    )\n    and r._field == \"value\"\n  )\n  |> map(fn: (r) => ({\n      r with\n      _value: float(v: r._value),\n  }))\n  |> drop(columns: [\"kind\", \"_field\"])"
                      }
                    },
                    "refId": "C",
                    "hidden": false
                  }
                }
